<div class="calendar-layout">

  <% current_date = params[:date]&.to_date || Date.today %>
  <% prev_month = current_date.prev_month %>
  <% next_month = current_date.next_month %>
  <% selected_date = params[:date]&.to_date || Date.today %>
  <% last_day = Date.new(current_date.year, current_date.month, -1).day %>

  <!-- ===================== -->
  <!-- 左：カレンダー -->
  <!-- ===================== -->
  <div class="calendar-box">
    <div class="calendar-inner">

      <div class="new-calendar-header">

        <%= link_to admin_reservations_list_path(
              view: "calendar",
              date: prev_month.beginning_of_month
            ),
            data: { turbo: false } do %>
          ‹
        <% end %>

        <h3><%= current_date.strftime("%Y年%-m月") %></h3>

        <%= link_to admin_reservations_list_path(
              view: "calendar",
              date: next_month.beginning_of_month
            ),
            data: { turbo: false } do %>
          ›
        <% end %>

      </div>

      <div class="calendar-week">
        <span>日</span>
        <span>月</span>
        <span>火</span>
        <span>水</span>
        <span>木</span>
        <span>金</span>
        <span>土</span>
      </div>

      <div class="admin-calendar-grid">
        <% start_wday = Date.new(current_date.year, current_date.month, 1).wday %>

        <% start_wday.times do %>
          <div></div>
        <% end %>

        <% (1..last_day).each do |day| %>
          <% date = Date.new(current_date.year, current_date.month, day) %>
          <% has_reservation = @reserved_dates.map(&:to_date).include?(date) %>
          <% count = @reservation_counts[date] || 0 %>

          <%= link_to admin_reservations_list_path(
            view: "calendar",
            date: date
          ),
          class: "admin-calendar-day #{'selected' if selected_date == date} ",
          data: { turbo: false } do %>

            <div class="day-number"><%= day %></div>

            <% if count > 0 %>
              <div class="day-count"><%= count %></div>
            <% end %>

          <% end %>
        <% end %>
      </div>
    </div>

  </div>

  <!-- ===================== -->
  <!-- 右：予約詳細 -->
  <!-- ===================== -->
  <div class="calendar-detail">

    <% service_labels = {
      "kindergarten" => "犬の幼稚園",
      "nursery" => "保育園",
      "hotel" => "ホテル",
      "temporary_care" => "一時預かり"
    } %>

    <% if selected_date.present? %>

      <h3><%= selected_date.strftime("%-m月%-d日") %>の予約</h3>

      <% if @daily_reservations_grouped.any? %>

        <% @daily_reservations_grouped.each do |service, reservations| %>

          <div class="service-group">

            <div class="service-header">
              <span>🏷 <%= service_labels[service] %></span>
              <span>(<%= reservations.count %>件)</span>
            </div>

            <% reservations.each do |r| %>
              <div class="booking-card">

                <div class="time-box">
                  <div class="time">
                    <%= r.reserved_time&.split(" - ")&.first %>
                  </div>
                </div>

                <div class="booking-info">
                  <%= r.customer&.owner_name %>
                  <div class="dog-name">
                    <%= r.customer&.dog_name %>
                  </div>
                </div>

                <div class="booking-meta">
                  <div class="price">¥8,000</div>
                  <div class="status-badge confirmed">確定</div>
                </div>

              </div>
            <% end %>

          </div>

        <% end %>

      <% else %>
        <p>予約はありません</p>
      <% end %>

    <% else %>
      <p>日付を選択してください</p>
    <% end %>

  </div>

</div>