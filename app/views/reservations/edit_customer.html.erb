<div class="admin-layout">

  <%= render "shared/sidebar" %>

  <main class="admin-main new-customer-page">

    <div class="back-link">
      <%= link_to "/admin/customers" do %>
        <i class="bi bi-arrow-left"></i>
        顧客一覧に戻る
      <% end %>
    </div>

    <div class="page-title">
      <h1>顧客編集</h1>
      <p>顧客情報を更新します</p>
    </div>

    <div class="customer-form-card">
      <h2>顧客情報</h2>

      <%= form_with model: @customer,
        url: update_customer_path(@customer),
        method: :patch do |f| %>

        <div class="form-grid">

          <div class="form-group">
            <%= f.label :owner_name, "名前 *" %>
            <%= f.text_field :owner_name %>
          </div>

          <div class="form-group">
            <%= f.label :phone_number, "電話番号 *" %>
            <%= f.text_field :phone_number %>
          </div>

          <div class="form-group">
            <%= f.label :dog_name, "犬名" %>
            <%= f.text_field :dog_name %>
          </div>

          <div class="form-group">
            <%= f.label :dog_breed, "犬種" %>
            <%= f.text_field :dog_breed %>
          </div>

          <div class="form-group">
            <%= f.label :dog_age, "年齢" %>
            <%= f.text_field :dog_age %>
          </div>

          <div class="form-group">
            <%= f.label :dog_gender, "性別" %>
            <%= f.select :dog_gender,
              ["オス", "メス"],
              {},
              class: "form-select" %>
          </div>

          <div class="form-group full-span">
            <%= f.label :address, "住所" %>
            <%= f.text_field :address %>
          </div>

        </div>

        <div class="form-actions">
          <%= f.submit "更新する", class: "submit-btn" %>

          <%= link_to "キャンセル",
            "/admin/customers",
            class: "cancel-btn" %>
        </div>

      <% end %>
    </div>

  </main>
</div>