<div class="admin-layout">

  <%= render "shared/sidebar" %>

  <main class="admin-main">

    <!-- ヘッダー -->
    <div class="customers-header">

      <div class="header-left">
        <h1>予約管理</h1>
        <p>予約の管理と閲覧</p>

        <!-- トグルはここ -->
        <div class="view-toggle">
          <%= link_to "リスト表示",
            admin_reservations_list_path(view: "list"),
            class: "toggle-btn #{'active' if @view == 'list'}" %>

          <%= link_to "カレンダー表示",
            admin_reservations_list_path(view: "calendar"),
            class: "toggle-btn #{'active' if @view == 'calendar'}" %>
        </div>
      </div>

      <!-- 右はボタンだけ -->
      <div class="header-right">
        <%= link_to new_admin_reservation_path,
          class: "add-customer-btn" do %>
          ＋ 新規予約追加
        <% end %>
      </div>

    </div>

    <!-- コンテンツ -->
    <% if @view == "calendar" %>
      <turbo-frame id="main_view">
        <%= render @view %>
      </turbo-frame>
    <% else %>
      <div class="reservations-card">
        <turbo-frame id="main_view">
          <%= render @view %>
        </turbo-frame>
      </div>
    <% end %>

  </main>

</div>