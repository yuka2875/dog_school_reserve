<div class="admin-layout">
  <%= render "shared/sidebar" %>

  <main class="admin-main">

    <!-- ヘッダー -->
    <div class="sns-header">
      <h1>ダッシュボード</h1>
      <p><%= Date.today.strftime("%Y年%m月%d日（%a）") %></p>
    </div>

    <!-- 上段カード -->
    <div class="dashboard-grid">

      <!-- 今日の予約 -->
      <div class="dashboard-card stat">
        <div class="stat-content">
          <div>
            <p class="stat-label">今日の予約件数</p>
            <p class="stat-value"><%= @reservations.where(reserved_date: Date.today).count %></p>
          </div>
          <div class="icon-circle blue">
            <i class="bi bi-calendar3"></i>
          </div>
        </div>
      </div>

      <!-- 幼稚園 -->
      <div class="dashboard-card stat">
        <div class="stat-content">
          <div>
            <p class="stat-label">幼稚園</p>
            <p class="stat-value">
              <%= @reservations.where(reserved_date: Date.today, service_type: "kindergarten").count %>
            </p>
          </div>
          <div class="icon-circle green">
            <i class="bi bi-house"></i>
          </div>
        </div>
      </div>

      <!-- ホテル -->
      <div class="dashboard-card stat">
        <div class="stat-content">
          <div>
            <p class="stat-label">ホテル</p>
            <p class="stat-value">
              <%= @reservations.where(reserved_date: Date.today, service_type: "hotel").count %>
            </p>
          </div>
          <div class="icon-circle purple">
            <i class="bi bi-building"></i>
          </div>
        </div>
      </div>

      <!-- 一時預かり -->
      <div class="dashboard-card stat">
        <div class="stat-content">
          <div>
            <p class="stat-label">一時預かり</p>
            <p class="stat-value">
              <%= @reservations.where(reserved_date: Date.today, service_type: "temporary_care").count %>
            </p>
          </div>
          <div class="icon-circle orange">
            <i class="bi bi-clock"></i>
          </div>
        </div>
      </div>

    </div>

    <!-- 中段 -->
    <div class="dashboard-grid-2">

      <!-- 送迎 -->
      <div class="dashboard-card">
        <h2>今日の送迎</h2>

        <% if @pickup_addresses.present? %>
          <% @pickup_addresses.each do |address| %>
            <div class="pickup-row">
              <span>📍</span>
              <span><%= address %></span>
            </div>
          <% end %>

          <% store_address = "〒812-0012 福岡県福岡市博多区博多駅中央街１−１" %>
          <% route_url =
            "https://www.google.com/maps/dir/" +
            CGI.escape(store_address) + "/" +
            @pickup_addresses.map { |a| CGI.escape(a) }.join("/") +
            "/" +
            CGI.escape(store_address)
          %>

          <%= link_to "送迎ルートを見る", route_url, target: "_blank", class: "sns-button" %>
        <% else %>
          <p>送迎予定なし</p>
        <% end %>
      </div>

      <!-- スケジュール -->
      <div class="dashboard-card">
        <h2>今日のスケジュール</h2>

        <div class="schedule-list">
          <% @time_slots.each do |slot| %>
            <div class="schedule-row <%= slot[:available] > 0 ? 'available' : 'full' %>">
              <span class="time"><%= slot[:time] %></span>

              <% if slot[:available] > 0 %>
                <span class="status available">空きあり（<%= slot[:available] %>）</span>
              <% else %>
                <span class="status full">満席</span>
              <% end %>
            </div>
          <% end %>
        </div>

      </div>

    </div>

    
  </main>
</div>