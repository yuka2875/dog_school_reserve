<div class="admin-layout">

  <%= render "shared/sidebar" %>

  <div class="admin-main reservation-page new-customer-page admin-reservation-page">

    <div class="back-link">
      <%= link_to admin_reservations_list_path do %>
        <i class="bi bi-arrow-left"></i>
        予約一覧に戻る
      <% end %>
    </div>

    <div class="page-title">
      <h1>新規予約追加</h1>
      <p>新しい予約を登録します</p>
    </div>

    <%= form_with model: @reservation,
      url: review_admin_reservations_path,
      method: :post,
      data: { turbo: false } do |f| %>

      <div class="admin-reservation-container">

        <!-- 日付 + 時間 -->
        <div class="admin-date-time-card">

          <!-- 日付 -->
          <div class="form-group">
            <label>日付</label>
            <%= f.date_field :reserved_date, class: "input-field" %>
          </div>

          <!-- 時間 -->
          <div class="admin-time-list">

            <label>時間</label>

            <% @time_slots.each do |slot| %>
              <% disabled = slot[:available] == 0 %>

              <label class="time-item <%= 'disabled' if disabled %>">

                <%= f.radio_button :reserved_time, slot[:value], disabled: disabled %>

                <div class="time-content">
                  <span class="time-text"><%= slot[:value] %></span>
                  <span class="time-meta">
                    <%= slot[:available] %> / <%= slot[:total] %>
                  </span>
                </div>

              </label>

            <% end %>

          </div>

        </div>

        <!-- 予約情報 -->
        <div class="customer-form-card">

          <h2>予約情報</h2>

          <div class="form-grid">

            <div class="form-group">
              <%= f.label :customer_id, "顧客 *" %>

              <%= f.collection_select :customer_id,
                Customer.all,
                :id,
                :owner_name,
                { prompt: "顧客を選択してください" },
                class: "form-select" %>
            </div>

            <div class="form-group">
              <%= f.label :service_type, "サービス" %>
              <%= f.select :service_type,
                [
                  ["犬の幼稚園", "kindergarten"],
                  ["保育園", "nursery"],
                  ["ホテル", "hotel"],
                  ["一時預かり", "temporary_care"]
                ],
                {},
                class: "form-select" %>
            </div>

            <div class="form-group">
              <%= f.label :pickup_required, "送迎" %>

              <%= f.select :pickup_required,
                [
                  ["なし", false],
                  ["あり", true]
                ],
                {},
                class: "form-select" %>
            </div>

          </div>

          <%= hidden_field_tag :date, @selected_date %>

          <div class="form-actions">
            <%= f.submit "確認へ進む", class: "submit-btn" %>

            <%= link_to "キャンセル",
              "/admin/reservations",
              class: "cancel-btn" %>
          </div>

        </div>

      </div>

    <% end %>

  </div>
</div>