<table class="reservations-table">
  <thead>
    <tr>
      <th>日時</th>
      <th>顧客名</th>
      <th>犬名</th>
      <th>電話</th>
      <th>操作</th>
    </tr>
  </thead>

  <tbody>
    <% @reservations.each do |r| %>
      <tr>
        <td>
          <div class="reservation-datetime">
            <span class="reservation-date"><%= r.reserved_date %></span>
            <span class="reservation-time"><%= r.reserved_time %></span>
          </div>
        </td>

        <td class="customer-name">
          <div class="cell-with-icon">
            <i class="bi bi-person"></i>
            <%= r.customer&.owner_name %>
          </div>
        </td>

        <td>
          <div class="cell-with-icon">
            <i class="bi bi-heart"></i>
            <%= r.customer&.dog_name %>
          </div>
        </td>

        <td>
          <div class="cell-with-icon">
            <i class="bi bi-telephone"></i>
            <%= r.customer&.phone_number %>
          </div>
        </td>

        <td class="action-buttons">
          <%= link_to "#", class: "icon-btn edit-btn" do %>
            <i class="bi bi-pencil"></i>
          <% end %>

          <%= button_to "#",
            method: :delete,
            data: { confirm: "削除しますか？" },
            class: "icon-btn delete-btn" do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>